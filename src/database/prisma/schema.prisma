generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Books {
  title             String
  ISBN              String      @unique
  author            String
  publisher         String
  category          String[]
  year              String
  availableQuantity Int
  id                Int         @id @default(autoincrement())
  loanItems         LoanItems[]
}

model Readers {
  id       Int     @id @default(autoincrement())
  publicId String  @unique @default(uuid())
  name     String
  email    String  @unique
  phone    String
  bio      String?
  loans    Loans[]
}

model Loans {
  id                 String      @id @unique @default(uuid())
  loanDate           DateTime    @default(now())
  expectedReturnDate DateTime
  returnDate         DateTime?
  status             LoansStatus
  readerId           Int
  loanItems          LoanItems[]
  reader             Readers     @relation(fields: [readerId], references: [id])
}

model LoanItems {
  id       Int    @id @default(autoincrement())
  quantity Int    @default(1)
  loanId   String
  bookId   Int
  book     Books  @relation(fields: [bookId], references: [id])
  loan     Loans  @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@unique([loanId, bookId])
}

enum LoansStatus {
  CANCELLED
  DAMAGED
  EXPIRED
  LOST
  OVERDUE
  RENEWED
  REQUESTED
  RETURNED
}
